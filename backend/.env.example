PORT=5000
# For MongoDB Atlas, paste your SRV connection string
# Example:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fixifyplus?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fixifyplus?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
JWT_EXPIRES_IN=7d
RATE_LIMIT_MAX=300
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@fixify.local
